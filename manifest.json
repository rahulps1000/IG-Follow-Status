{
	"manifest_version": 3,
	"name": "IG Follow Status",
	"short_name": "IG Follow Status",
	"description": "Shows relationship status on Instagram profiles",
	"version": "1.0.0",
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_popup": "popup/popup.html",
		"default_title": "Instagram Follow Status",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png"
		}
	},
	"permissions": ["storage"],
	"host_permissions": ["https://www.instagram.com/*"],
	"content_scripts": [
		{
			"matches": ["https://www.instagram.com/*"],

			"js": [
				"shared/constants.js",
				"shared/storage.js",
				"content/badge.js",
				"content/content.js"
			],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["content/inject.js"],
			"matches": ["https://www.instagram.com/*"]
		}
	]
}
